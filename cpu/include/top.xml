<?xml version="1.0" encoding="UTF-8"?>
<nf:module xmlns:nf="http://www.NetFPGA.org/NF2_register_system" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xsi:schemaLocation="http://www.NetFPGA.org/NF2_register_system NF2_register_system.xsd ">

    <nf:name>top</nf:name>
    <nf:prefix>top</nf:prefix>
    <nf:location>udp</nf:location>
    <nf:description>Register interface for the CPU top module</nf:description>
    <nf:blocksize>64</nf:blocksize>

    <nf:registers>

        <!-- ================= Software Registers ================= -->

        <nf:register>
            <nf:name>sw_req_cmd</nf:name>
            <nf:description>MMIO request command (bit[0])</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_req_addr</nf:name>
            <nf:description>MMIO request address</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_req_data_lo</nf:name>
            <nf:description>MMIO write data [31:0]</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_req_data_hi</nf:name>
            <nf:description>MMIO write data [63:32]</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_req_val</nf:name>
            <nf:description>Request valid (bit[0])</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_resp_rdy</nf:name>
            <nf:description>Response ready (bit[0])</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>sw_cpu_start</nf:name>
            <nf:description>CPU start (bit[0])</nf:description>
            <nf:type>generic_software32</nf:type>
        </nf:register>

        <!-- ================= Hardware Registers ================= -->

        <nf:register>
            <nf:name>hw_req_rdy</nf:name>
            <nf:description>Request ready (bit[0])</nf:description>
            <nf:type>generic_hardware32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>hw_resp_data_lo</nf:name>
            <nf:description>MMIO read data [31:0]</nf:description>
            <nf:type>generic_hardware32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>hw_resp_data_hi</nf:name>
            <nf:description>MMIO read data [63:32]</nf:description>
            <nf:type>generic_hardware32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>hw_resp_val</nf:name>
            <nf:description>Response valid (bit[0])</nf:description>
            <nf:type>generic_hardware32</nf:type>
        </nf:register>

        <nf:register>
            <nf:name>hw_fifo</nf:name>
            <nf:description>Response fifo packet ready</nf:description>
            <nf:type>generic_hardware32</nf:type>
        </nf:register>

    </nf:registers>
</nf:module>